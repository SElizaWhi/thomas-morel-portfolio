---
const skills = ["Figma", "Photoshop", "Illustrator", "After Effects", "Lightroom", "Premiere"];
---

<section id="about" class="about bb">
  <div class="about-monogram">
    <span class="monogram">TM</span>
    <span class="location">Nîmes, FR</span>
  </div>

  <div class="about-content">
    <p class="section-label" style="border: none; padding: 0;" data-i18n="about.label">À propos</p>

    <p class="about-text" data-i18n="about.text">
      Designer multidisciplinaire basé à Nîmes. Je conçois des identités visuelles,
      sites web et contenus photo/vidéo pour des marques qui veulent se démarquer.
    </p>

    <div class="about-skills">
      {skills.map(skill => (
        <span class="tag">{skill}</span>
      ))}
    </div>
  </div>
</section>

<style>
  .about {
    display: grid;
    grid-template-columns: 1fr 2fr;
    margin-bottom: 3rem;
  }

  .about-monogram {
    background: var(--noir);
    color: var(--cream);
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .monogram {
    font-size: 72px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -3px;
  }

  .location {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-top: 8px;
    opacity: 0.7;
  }

  .about-content {
    padding: 3rem;
    background: var(--cream);
  }

  .about-text {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text);
    margin-bottom: 20px;
    max-width: 540px;
  }

  .about-skills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .about {
      grid-template-columns: 1fr;
    }

    .about-monogram {
      padding: 1.5rem;
      flex-direction: row;
      align-items: baseline;
      gap: 12px;
    }
  }
</style>
