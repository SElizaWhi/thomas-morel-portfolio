---
const skills = [
  { name: "Figma", color: "#FFD23F", bg: "#3D2E00" },
  { name: "Photoshop", color: "#45B7D1", bg: "#1A2F4F" },
  { name: "Illustrator", color: "#F5A623", bg: "#3D1F00" },
  { name: "After Effects", color: "#9B5DE5", bg: "#2A1045" },
  { name: "Lightroom", color: "#3BCEAC", bg: "#0E3528" },
  { name: "Premiere", color: "#45B7D1", bg: "#1A3540" },
];
---

<section id="about" class="about">
  <div class="about-card bb card">
    <div class="about-monogram">
      <span class="monogram">TM</span>
      <span class="location">Nîmes, FR</span>
    </div>

    <div class="about-content">
      <p
        class="section-label"
        style="border: none; padding: 0;"
        data-i18n="about.label"
      >
        À propos
      </p>

      <p class="about-text" data-i18n="about.text">
        Designer multidisciplinaire basé à Nîmes. Je conçois des identités
        visuelles, sites web et contenus photo/vidéo pour des marques qui
        veulent se démarquer.
      </p>

      <div class="about-skills">
        {
          skills.map((skill) => (
            <span
              class="tag"
              style={`background: ${skill.bg}; color: ${skill.color}; border-color: ${skill.color};`}
            >
              {skill.name}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding: 4rem 0;
    margin-bottom: 3rem;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .about-card {
    display: grid;
    grid-template-columns: 1fr 2fr;
    width: 100%;
    max-width: 800px;
  }

  .about-monogram {
    background: var(--noir);
    color: var(--cream);
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .monogram {
    font-size: 72px;
    font-weight: 1000;
    line-height: 1;
    letter-spacing: -3px;
    text-shadow: 4px 5px 0 var(--vert);
  }

  .location {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-top: 8px;
    opacity: 0.7;
  }

  .about-content {
    padding: 3rem;
    background: var(--cream);
  }

  .about-text {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text);
    margin-bottom: 20px;
    max-width: 540px;
  }

  .about-skills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .about {
      padding: 2rem 0;
      margin-bottom: 1rem;
    }

    .about-card {
      grid-template-columns: 1fr;
    }

    .about-monogram {
      padding: 1.5rem 2rem;
      flex-direction: row;
      align-items: baseline;
      gap: 12px;
    }

    .about-content {
      padding: 1.5rem 2rem;
    }

    .monogram {
      font-size: 48px;
    }
  }
</style>
