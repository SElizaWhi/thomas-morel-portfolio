---
import fs from "node:fs";
import path from "node:path";
import ProjectCard from "./ProjectCard.astro";
import projets from "../data/projets.json";

const projetsDir = path.join(process.cwd(), "public/images/projets");
const validExts = new Set([".jpg", ".jpeg", ".png", ".webp", ".avif"]);

function getProjectImages(id: string): string[] {
  const dir = path.join(projetsDir, id);
  if (!fs.existsSync(dir)) return [];
  return fs
    .readdirSync(dir)
    .filter((f) => validExts.has(path.extname(f).toLowerCase()))
    .sort()
    .map((f) => `/images/projets/${id}/${f}`);
}

const withImages = projets.map((p) => ({
  ...p,
  images: getProjectImages(p.id),
  image: getProjectImages(p.id)[0] ?? null,
}));

const topRow = withImages.filter(
  (p) => p.size === "large" || p.size === "tall",
);
const bottomRow = withImages.filter((p) => p.size === "small");
---

<section id="projets">
  <p class="section-label" data-i18n="projects.label">Projets sélectionnés</p>

  <div class="grid-top">
    {topRow.map((projet) => <ProjectCard projet={projet} />)}
  </div>

  <div class="grid-bottom">
    {bottomRow.map((projet) => <ProjectCard projet={projet} />)}
  </div>
</section>

<!-- Project Modal -->
<div class="project-modal" id="project-modal" aria-modal="true" role="dialog">
  <div class="modal-overlay" id="modal-overlay"></div>
  <div class="modal-content">
    <button class="modal-close" id="modal-close" aria-label="Fermer"
      >&times;</button
    >
    <div class="modal-left">
      <p class="modal-category"></p>
      <h2 class="modal-title"></h2>
      <p class="modal-description"></p>
      <button class="modal-close-bottom" id="modal-close-bottom" aria-label="Fermer">Fermer</button>
    </div>
    <div class="modal-right">
      <div class="modal-images"></div>
    </div>
  </div>
</div>

<!-- Image lightbox (above modal) -->
<div class="img-lb" id="img-lb">
  <div class="img-lb-bg" id="img-lb-bg"></div>
  <button class="img-lb-close" id="img-lb-close">&times;</button>
  <button class="img-lb-prev" id="img-lb-prev">&#8249;</button>
  <button class="img-lb-next" id="img-lb-next">&#8250;</button>
  <img id="img-lb-img" src="" alt="" />
  <div class="img-lb-counter" id="img-lb-counter"></div>
</div>

<style>
  :global(#projets) {
    padding: 3rem 0 6rem;
  }

  .grid-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .grid-bottom {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .grid-bottom {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .grid-top,
    .grid-bottom {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .grid-top {
      margin-bottom: 1.5rem;
    }
  }

  /* Modal */
  .project-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 10000;
    align-items: center;
    justify-content: center;
  }

  .project-modal.active {
    display: flex;
  }

  .modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 26, 26, 0.85);
  }

  .modal-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 320px 1fr;
    width: 100%;
    height: 100%;
    background: var(--bg);
    border: none;
    overflow: hidden;
  }

  .modal-close {
    position: absolute;
    top: 10px;
    right: 14px;
    background: none;
    border: none;
    font-size: 28px;
    cursor: pointer;
    color: var(--text);
    z-index: 2;
    line-height: 1;
  }

  .modal-left {
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-right: var(--border);
    overflow-y: auto;
  }

  .modal-category {
    font-size: 16px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
  }

  .modal-title {
    font-size: 32px;
    font-weight: 800;
    line-height: 1.1;
  }

  .modal-description {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-muted);
    margin-top: 4px;
  }

  .modal-right {
    overflow-y: auto;
    padding: 16px;
    background: var(--cream);
  }

  .modal-images {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 8px;
  }

  .modal-images img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
    cursor: pointer;
    border: var(--border);
    transition: opacity 0.15s;
  }

  .modal-images img:hover {
    opacity: 0.85;
  }

  .modal-close-bottom {
    margin-top: auto;
    align-self: center;
    background: var(--bg);
    color: var(--text);
    border: var(--border);
    padding: 8px 28px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: 3px 3px 0 0 var(--border-color);
  }

  .modal-close-bottom:hover {
    background: var(--text);
    color: var(--bg);
  }

  @media (max-width: 640px) {
    .modal-content {
      grid-template-columns: 1fr;
    }

    .modal-left {
      border-right: none;
      border-bottom: var(--border);
      padding: 24px 20px;
    }
  }

  /* Image lightbox */
  .img-lb {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 20000;
    align-items: center;
    justify-content: center;
    flex-direction: column;
  }

  .img-lb.active {
    display: flex;
  }

  .img-lb-bg {
    position: absolute;
    inset: 0;
    background: rgba(26, 26, 26, 0.97);
  }

  .img-lb img {
    position: relative;
    max-width: 88vw;
    max-height: 82vh;
    object-fit: contain;
    border: var(--border);
    border-color: #fffdf5;
  }

  .img-lb-close {
    position: absolute;
    top: 20px;
    right: 24px;
    background: none;
    border: none;
    color: #fffdf5;
    font-size: 36px;
    cursor: pointer;
    z-index: 1;
    line-height: 1;
  }

  .img-lb-prev,
  .img-lb-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #fffdf5;
    font-size: 48px;
    cursor: pointer;
    padding: 0 16px;
    z-index: 1;
  }

  .img-lb-prev {
    left: 8px;
  }
  .img-lb-next {
    right: 8px;
  }

  .img-lb-counter {
    position: relative;
    color: #fffdf5;
    font-size: 12px;
    margin-top: 14px;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 0.6;
  }

  /* --- fun mode: modal neobrutalist --- */
  :global([data-theme="fun"]) .modal-content {
    border: 5px solid #1a1a1a;
    border-radius: 0;
    box-shadow: 12px 12px 0 0 #1a1a1a;
    max-width: calc(100% - 40px);
    max-height: calc(100% - 40px);
    width: calc(100% - 40px);
    height: calc(100% - 40px);
  }

  :global([data-theme="fun"]) .modal-left {
    border-right: 5px solid #1a1a1a;
    background: var(--jaune);
  }

  :global([data-theme="fun"]) .modal-title {
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -1px;
    text-transform: uppercase;
  }

  :global([data-theme="fun"]) .modal-category {
    font-weight: 800;
    letter-spacing: 3px;
    font-size: 13px;
    color: #1a1a1a;
  }

  :global([data-theme="fun"]) .modal-close {
    font-size: 32px;
    font-weight: 800;
    color: #1a1a1a;
  }

  :global([data-theme="fun"]) .modal-close-bottom {
    border-radius: 0;
    border: 4px solid #1a1a1a;
    box-shadow: 5px 5px 0 0 #1a1a1a;
    font-weight: 800;
    letter-spacing: 2px;
    background: var(--ambre);
  }

  :global([data-theme="fun"]) .modal-images img {
    border: 4px solid #1a1a1a;
    border-radius: 0;
    box-shadow: 4px 4px 0 0 #1a1a1a;
    transition: transform 0.12s, box-shadow 0.12s;
  }

  :global([data-theme="fun"]) .modal-images img:hover {
    opacity: 1;
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 0 #1a1a1a;
  }
</style>

<script
  is:inline
  define:vars={{
    projectsData: withImages.map((p) => ({
      id: p.id,
      title: p.title,
      category: p.category,
      description: p.description ?? "",
      images: p.images,
    })),
  }}
>
  // Modal
  const modal = document.getElementById("project-modal");
  const overlay = document.getElementById("modal-overlay");
  const closeBtnBottom = document.getElementById("modal-close-bottom");
  const modalCategory = modal.querySelector(".modal-category");
  const modalTitle = modal.querySelector(".modal-title");
  const modalDescription = modal.querySelector(".modal-description");
  const modalImages = modal.querySelector(".modal-images");

  // Lightbox
  const lb = document.getElementById("img-lb");
  const lbBg = document.getElementById("img-lb-bg");
  const lbImg = document.getElementById("img-lb-img");
  const lbClose = document.getElementById("img-lb-close");
  const lbPrev = document.getElementById("img-lb-prev");
  const lbNext = document.getElementById("img-lb-next");
  const lbCounter = document.getElementById("img-lb-counter");

  let lbSrcs = [];
  let lbCurrent = 0;

  function openLb(srcs, index) {
    lbSrcs = srcs;
    lbCurrent = index;
    lbImg.src = lbSrcs[lbCurrent];
    lbCounter.textContent = `${lbCurrent + 1} / ${lbSrcs.length}`;
    lb.classList.add("active");
  }

  function closeLb() {
    lb.classList.remove("active");
  }

  function lbNavigate(dir) {
    lbCurrent = (lbCurrent + dir + lbSrcs.length) % lbSrcs.length;
    lbImg.src = lbSrcs[lbCurrent];
    lbCounter.textContent = `${lbCurrent + 1} / ${lbSrcs.length}`;
  }

  lbClose.addEventListener("click", closeLb);
  lbBg.addEventListener("click", closeLb);
  lbPrev.addEventListener("click", () => lbNavigate(-1));
  lbNext.addEventListener("click", () => lbNavigate(1));

  function openModal(id) {
    const project = projectsData.find((p) => p.id === id);
    if (!project) return;

    modalCategory.textContent = project.category;
    modalTitle.textContent = project.title;
    modalDescription.textContent = project.description;
    modalImages.innerHTML = project.images
      .map(
        (src, i) =>
          `<img src="${src}" alt="${project.title}" loading="lazy" data-index="${i}" />`,
      )
      .join("");

    modalImages.querySelectorAll("img").forEach((img) => {
      img.addEventListener("click", () =>
        openLb(project.images, Number(img.dataset.index)),
      );
    });

    modal.classList.add("active");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    modal.classList.remove("active");
    document.body.style.overflow = "";
  }

  document.querySelectorAll(".project-card").forEach((card) => {
    card.addEventListener("click", () => openModal(card.dataset.id));
  });

  overlay.addEventListener("click", closeModal);
  closeBtnBottom.addEventListener("click", closeModal);

  document.addEventListener("keydown", (e) => {
    if (lb.classList.contains("active")) {
      if (e.key === "Escape") closeLb();
      if (e.key === "ArrowLeft") lbNavigate(-1);
      if (e.key === "ArrowRight") lbNavigate(1);
    } else if (modal.classList.contains("active")) {
      if (e.key === "Escape") closeModal();
    }
  });
</script>
