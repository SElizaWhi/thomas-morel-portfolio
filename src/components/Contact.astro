<section id="contact" class="contact bb">
  <h2 class="contact-title" data-i18n="contact.title">Un projet en tête ?</h2>
  <p class="contact-subtitle" data-i18n-html="contact.subtitle">
    Je suis disponible pour des collaborations freelance.<br />
    Basé à Nîmes — travaille partout.
  </p>

  <form class="contact-form" action="https://formspree.io/f/xbdpggep" method="POST">
    <div class="form-row">
      <div class="form-group">
        <label for="name" data-i18n="contact.name">Nom</label>
        <input type="text" id="name" name="name" placeholder="Votre nom" data-i18n-placeholder="contact.name_placeholder" required />
      </div>
      <div class="form-group">
        <label for="email" data-i18n="contact.email">Email</label>
        <input type="email" id="email" name="email" placeholder="votre@email.com" required />
      </div>
    </div>

    <div class="form-group">
      <label for="message" data-i18n="contact.message">Message</label>
      <textarea id="message" name="message" rows="4" placeholder="Parlez-moi de votre projet..." data-i18n-placeholder="contact.message_placeholder" required></textarea>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary" data-i18n="contact.submit">Envoyer →</button>
      <a href="mailto:thomas@morel.design" class="btn btn-secondary" data-i18n="contact.email_btn">Ou par email</a>
    </div>
  </form>
</section>

