  /* --- Photo --- */
  .hero-photo-wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-photo-frame {
    position: relative;
  }

  .hero-photo {
    width: clamp(320px, 35vw, 500px);
    height: clamp(420px, 45vw, 700px);
    position: relative;
    overflow: hidden;
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  /* --- Tool stickers --- */
  .sticker {
    position: absolute;
    z-index: 2;
    width: 56px;
    height: 56px;
    border: var(--border);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .tool-label {
    font-size: 17px;
    font-weight: 700;
  }
  @media (max-width: 768px) {
    .hero {
      padding: 0 1.25rem;
      min-height: 100svh;
    }

    .sticker {
      display: none;
    }

    .hero-inner {
      flex-direction: column-reverse;
      gap: 1.5rem;
      padding: 2rem 0 3rem;
      align-items: flex-start;
    }

    .hero-photo-wrapper {
