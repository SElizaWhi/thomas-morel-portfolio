    }

    .hero-ctas .btn {
      text-align: center;
    }
  }
</style>

<script>
  const hero = document.querySelector<HTMLElement>(".hero");
  const stickers = document.querySelectorAll<HTMLElement>(".sticker");
  const THRESHOLD = 160;
  const MAX_PUSH = 22;

  function updateStickers(mouseX: number, mouseY: number) {
    stickers.forEach((sticker) => {
      const rect = sticker.getBoundingClientRect();
      if (rect.width === 0) return; // hidden in light mode
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      const dx = mouseX - cx;
      const dy = mouseY - cy;
      const dist = Math.sqrt(dx * dx + dy * dy);
      const rotate = sticker.dataset.rotate ?? "0";

      if (dist < THRESHOLD && dist > 0) {
        const strength = (1 - dist / THRESHOLD) * MAX_PUSH;
        const tx = -(dx / dist) * strength;
        const ty = -(dy / dist) * strength;
        sticker.style.transform = `translate(${tx}px, ${ty}px) rotate(${rotate}deg)`;
      } else {
        sticker.style.transform = `rotate(${rotate}deg)`;
      }
    });
  }

  hero?.addEventListener("mousemove", (e) =>
    updateStickers(e.clientX, e.clientY),
  );
  hero?.addEventListener("mouseleave", () => {
    stickers.forEach((s) => {
      const rotate = s.dataset.rotate ?? "0";
      s.style.transform = `rotate(${rotate}deg)`;
    });
  });
</script>
